# ============================================================
# OpenClaw AI CMO — Environment Configuration
# ============================================================
# Copy this to configs/.env and fill in your values

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_STRATEGY=qwen3:8b
OLLAMA_MODEL_CODE=qwen2.5-coder:7b

# SocialFlow Configuration
SOCIALFLOW_URL=http://localhost:8000
SOCIALFLOW_HEADLESS=false

# AI Provider for SocialFlow content generation (optional)
# Options: ollama (default), openai, anthropic, gemini
AI_PROVIDER=ollama

# Optional: External AI API keys (only if using cloud LLMs)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Discord Webhook (set in socialflow/backend/discord_webhook.json)
# DISCORD_WEBHOOK_URL=

# Workspace
WORKSPACE_ROOT=.
