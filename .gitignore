# ============================================================
# OpenClaw AI CMO — .gitignore
# ============================================================

# Large model files — DO NOT COMMIT
OllamaModels/

# Environment and secrets
.env
configs/.env
*.secret_key
socialflow/backend/.env
socialflow/backend/.secret_key

# Claude session data (contains conversation history)
.claude/

# OpenClaw local config (contains API keys)
.openclaw/

# Database
*.db
*.sqlite3

# Browser sessions (contain auth cookies)
socialflow/backend/sessions/
socialflow/sessions/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
*.egg

# Node
node_modules/
package-lock.json

# Uploads
socialflow/backend/uploads/

# macOS metadata
._*
.DS_Store
Thumbs.db
__MACOSX/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Log files (regenerated on each run)
OpenClawData/logs/
OpenClawData/inbharat-bot/logging/*.log

# Temp files
*.pid
*.tmp
TempFiles/

# Bridge logs
socialflow/backend/openclaw_bridge_log.json

# Playwright state
socialflow/backend/playwright-report/
_archive/
